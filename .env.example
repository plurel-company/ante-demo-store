# =============================================================================
# Plurel Pay Demo Store — environment variables
# Copy to .env.local for local dev. Never commit real secrets.
# PLUREL_* names are preferred; legacy ANTE_* / NEXT_PUBLIC_ANTE_* still work.
# Docs: https://plurelpay.com/docs/getting-started
# =============================================================================

# --- Public (embedded in the browser bundle) ---------------------------------

# Merchant ID from Plurel Pay dashboard → Developers (plurel_merch_* or legacy ante_merch_*)
NEXT_PUBLIC_PLUREL_MERCHANT_ID=plurel_merch_your_id
# NEXT_PUBLIC_ANTE_MERCHANT_ID=ante_merch_your_id

# Live publishable key — used when the header switch is set to Live
NEXT_PUBLIC_PLUREL_PUBLISHABLE_KEY=plurel_pk_live_your_key
# NEXT_PUBLIC_ANTE_PUBLISHABLE_KEY=ante_pk_live_your_key

# Optional explicit live key (overrides unqualified publishable key when set)
# NEXT_PUBLIC_PLUREL_PUBLISHABLE_KEY_LIVE=plurel_pk_live_your_key

# Test / sandbox publishable key — used when the header switch is set to Test
NEXT_PUBLIC_PLUREL_PUBLISHABLE_KEY_TEST=plurel_pk_test_your_key
# NEXT_PUBLIC_ANTE_PUBLISHABLE_KEY_TEST=ante_pk_test_your_key

# Absolute origin for product image URLs sent to hosted checkout.
NEXT_PUBLIC_SITE_URL=https://your-store.vercel.app

# --- Server only (never expose to the client) --------------------------------

# Cart HMAC signing secret — Developers → Signing
PLUREL_SIGNING_SECRET=plurel_sign_your_signing_secret
# ANTE_SIGNING_SECRET=ante_sign_your_signing_secret

# Secret API keys — Developers → Credentials (payments:write)
PLUREL_SECRET_KEY=plurel_sk_live_your_secret_key
PLUREL_SECRET_KEY_TEST=plurel_sk_test_your_secret_key
# ANTE_SECRET_KEY=ante_sk_live_your_secret_key
# ANTE_SECRET_KEY_TEST=ante_sk_test_your_secret_key

# Live webhook signing secret — Webhooks endpoint in dashboard (whsec_*)
PLUREL_WEBHOOK_SECRET=whsec_your_live_webhook_secret
PLUREL_WEBHOOK_SECRET_TEST=whsec_your_test_webhook_secret
# ANTE_WEBHOOK_SECRET=whsec_your_live_webhook_secret
# ANTE_WEBHOOK_SECRET_TEST=whsec_your_test_webhook_secret

# Optional upstream API override (defaults to https://plurelpay.com/api/v1)
# PLUREL_API_BASE=https://plurelpay.com/api/v1

# --- Observability (optional) ------------------------------------------------

# NEXT_PUBLIC_SENTRY_DSN=https://…@o….ingest.sentry.io/…
# SENTRY_DSN=https://…@o….ingest.sentry.io/…
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=plurelpay
# SENTRY_AUTH_TOKEN=…   (source map uploads)
