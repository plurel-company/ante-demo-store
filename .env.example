# Public — safe for the browser bundle
NEXT_PUBLIC_ANTE_MERCHANT_ID=ante_merch_your_id
NEXT_PUBLIC_ANTE_PUBLISHABLE_KEY=ante_pk_test_your_key
# Absolute URLs for product images sent to Ante (defaults to ante-demo-store.vercel.app)
NEXT_PUBLIC_SITE_URL=https://your-store.vercel.app

# Server only — never commit real values
ANTE_SIGNING_SECRET=ante_sign_your_signing_secret
ANTE_WEBHOOK_SECRET=whsec_your_webhook_secret
